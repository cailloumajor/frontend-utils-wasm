amends "package://github.com/jdx/hk/releases/download/v1.41.0/hk@1.41.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.41.0/hk@1.41.0#/Builtins.pkl"

local linters = new Mapping<String, Step> {
  ["betterleaks"] = Builtins.betterleaks
  ["deno"] = Builtins.deno
  ["deno-check"] = Builtins.deno_check
  ["deno-lint"] {
    glob = List("**/*.js", "**/*.jsx", "**/*.ts", "**/*.tsx")
    check = "deno lint {{ files }}"
    fix = "deno lint --fix {{ files }}"
  }
  ["editorconfig-checker"] = Builtins.editorconfig_checker
  ["mise"] = Builtins.mise
  ["pkl"] = Builtins.pkl
  ["pkl-format"] = Builtins.pkl_format
  ["rumdl"] = Builtins.rumdl
  ["tombi"] = Builtins.tombi
  ["typos"] = Builtins.typos
}

exclude = "CHANGELOG.md"

hooks {
  ["commit-msg"] {
    steps {
      ["check-conventional-commit"] = Builtins.check_conventional_commit
    }
  }
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps = linters
  }
  ["fix"] {
    fix = true
    steps = linters
  }
  ["check"] {
    steps = linters
  }
}
